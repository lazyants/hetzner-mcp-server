{
  "name": "@lazyants/hetzner-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for the Hetzner Cloud API — manage servers, networks, volumes, and more",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hetzner-mcp-server": "dist/index.js",
    "hetzner-mcp-servers": "dist/entry-servers.js",
    "hetzner-mcp-networking": "dist/entry-networking.js",
    "hetzner-mcp-load-balancers": "dist/entry-load-balancers.js",
    "hetzner-mcp-ips": "dist/entry-ips.js",
    "hetzner-mcp-storage": "dist/entry-storage.js",
    "hetzner-mcp-config": "dist/entry-config.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "check-versions": "node scripts/check-versions.mjs",
    "prepublishOnly": "node scripts/check-versions.mjs && npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "logo.png"
  ],
  "keywords": [
    "mcp",
    "hetzner",
    "cloud",
    "api",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lazyants/hetzner-mcp-server.git"
  },
  "mcpName": "io.github.lazyants/hetzner",
  "engines": {
    "node": ">=20"
  },
  "license": "FSL-1.1-MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.0"
  }
}
